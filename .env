# Docker Environment Configuration
# Copy this file to .env and update values as needed

# API Gateway
API_GATEWAY_PORT=3000

# User Service
USER_SERVICE_PORT=3001
USER_SERVICE_MONGODB_URI=mongodb+srv://sliitprojectmail_db_user:NsXpXAou9ovaVWxC@event-management-cluste.ygqctav.mongodb.net/user-service?retryWrites=true&w=majority
USER_SERVICE_JWT_SECRET=change_this_in_production
USER_SERVICE_JWT_EXPIRE=7d

# Event Service
EVENT_SERVICE_PORT=3002
EVENT_SERVICE_MONGODB_URI=mongodb://mongodb:27017/event-service
EVENT_SERVICE_KAFKA_BROKERS=kafka:29092

# Registration Service
REGISTRATION_SERVICE_PORT=3003
REGISTRATION_SERVICE_MONGODB_URI=mongodb://mongodb:27017/registration-service
REGISTRATION_SERVICE_KAFKA_BROKERS=kafka:29092
REGISTRATION_SERVICE_USER_SERVICE_URL=http://user-service:3001
REGISTRATION_SERVICE_EVENT_SERVICE_URL=http://event-service:3002

# Notification Service
NOTIFICATION_SERVICE_PORT=3004
NOTIFICATION_SERVICE_MONGODB_URI=mongodb://mongodb:27017/notification-service
NOTIFICATION_SERVICE_KAFKA_BROKERS=kafka:29092

# MongoDB
MONGODB_PORT=27017

# Kafka
KAFKA_PORT=9092
ZOOKEEPER_PORT=2181

# Frontend
FRONTEND_PORT=80

# Node Environment
NODE_ENV=development
LOG_LEVEL=debug
